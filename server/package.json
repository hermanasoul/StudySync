{
  "name": "studysync-server",
  "version": "1.3.0",
  "description": "Backend server for StudySync application with notifications, caching, WebSocket and real-time features",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed:subjects": "node seedSubjects.js",
    "seed:notifications": "node scripts/seedNotifications.js",
    "db:init": "node scripts/initDB.js",
    "db:migrate": "node scripts/migrate.js",
    "redis:flush": "node scripts/redisFlush.js",
    "redis:monitor": "redis-cli monitor",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "docker:redis": "docker run --name studysync-redis -p 6379:6379 -d redis:alpine",
    "docker:clean": "docker stop studysync-redis && docker rm studysync-redis"
  },
  "keywords": [
    "studysync",
    "education",
    "backend",
    "notifications",
    "caching",
    "websocket",
    "realtime"
  ],
  "author": "StudySync Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hermanasoul/StudySync.git"
  },
  "bugs": {
    "url": "https://github.com/hermanasoul/StudySync/issues"
  },
  "homepage": "https://github.com/hermanasoul/StudySync#readme"
}
